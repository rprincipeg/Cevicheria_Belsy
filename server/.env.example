DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/cevicheria_belsy_db?schema=public"

NODE_ENV=development
PORT=3001
JWT_SECRET=your_jwt_secret_here

# Gmail SMTP — necesario para envío de comprobantes por email (Had-01 criterio 7)
# Usar una App Password de Google, no la contraseña de la cuenta
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# URL pública del cliente (para CORS). En Railway, la URL pública del servicio.
CLIENT_URL=

# Almacenamiento de archivos. En producción apuntar a un Volume persistente
# para que las imágenes de platos y los PDFs/Excel NO se borren en cada redeploy.
# Railway: montar un Volume en /data y usar:
#   UPLOADS_DIR=/data/uploads
#   RECEIPTS_DIR=/data/receipts
# Si se dejan vacías, usan server/uploads y server/receipts (por defecto).
UPLOADS_DIR=
RECEIPTS_DIR=
    