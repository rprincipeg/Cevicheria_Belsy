generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MESERO
  COCINERO
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum StockStatus {
  AVAILABLE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED
  PAID
  CANCELLED // -EDITADOv6
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED // -EDITADOv7 (entrega por ítem)
  CANCELLED // -EDITADOv6
}

enum SupplyUnit {
  KG
  G
  L
  ML
  UNITS
} // -NUEVOv5

// ─── CATEGORY ────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MenuItem[]

  @@map("categories")
}

// ─── MENU ITEM ────────────────────────────────────────────────────────────────

model MenuItem {
  id           String      @id @default(cuid())
  name         String      @unique
  description  String?
  price        Decimal     @db.Decimal(10, 2)
  stockStatus  StockStatus @default(AVAILABLE)
  isPreparable Boolean     @default(true)
  isActive     Boolean     @default(true) // soft-delete: platos con historial de pedidos se ocultan en vez de borrarse
  imageUrl     String?
  categoryId   String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  category    Category     @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  recipeItems RecipeItem[] // -NUEVOv5

  @@map("menu_items")
}

// ─── DINING TABLE ─────────────────────────────────────────────────────────────

model DiningTable {
  id           Int      @id @default(autoincrement())
  number       Int      @unique
  status       String   @default("FREE")
  mergedIntoId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mergedInto    DiningTable?  @relation("TableMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedSources DiningTable[] @relation("TableMerge")
  orders        Order[]
  payments      Payment[]
  incidents     Incident[] // -EDITADOv6

  @@map("dining_tables")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  fullName     String?
  username     String     @unique
  passwordHash String
  role         UserRole   @default(MESERO)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orders          Order[]        @relation("OrderCreatedBy")
  deliveredOrders Order[]        @relation("OrderDeliveredBy")
  payments        Payment[]
  closures        DailyClosure[]
  incidents       Incident[]     // -EDITADOv6

  @@map("users")
} // -EDITADOv2 -EDITADOv3 -EDITADOv6

// ─── ORDER ────────────────────────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  code          String      @unique
  tableId       Int?
  createdById   String
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2) @default(0)
  isTakeaway    Boolean     @default(false)
  notes         String?
  paidAt        DateTime?
  deliveredAt   DateTime?
  deliveredById String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  table       DiningTable? @relation(fields: [tableId], references: [id])
  createdBy   User         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  deliveredBy User?        @relation("OrderDeliveredBy", fields: [deliveredById], references: [id])
  items       OrderItem[]
  payments    Payment[]

  @@map("orders")
} // -EDITADOv2

// ─── ORDER ITEM ───────────────────────────────────────────────────────────────

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  menuItemId String          @map("menuitemid")
  quantity   Int
  unitPrice  Decimal         @db.Decimal(10, 2)
  subtotal   Decimal         @db.Decimal(10, 2)
  status     OrderItemStatus @default(PENDING)
  isTakeaway Boolean         @default(false)
  readyAt    DateTime?
  paidAt     DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

// ─── DAILY CLOSURE ───────────────────────────────────────────────────────────

model DailyClosure {
  id           String   @id @default(cuid())
  date         String   // YYYY-MM-DD (UTC) — unique per calendar day
  totalSales   Decimal  @db.Decimal(10, 2)
  totalOrders  Int
  tablesServed Int
  closedById   String
  excelPath    String?
  closedBy     User     @relation(fields: [closedById], references: [id])
  createdAt    DateTime @default(now())

  @@map("daily_closures")
} // -NUEVOv3

// ─── PAYMENT ──────────────────────────────────────────────────────────────────

model Payment {
  id               String   @id @default(cuid())
  orderId          String?
  tableId          Int?
  receivedById     String
  amount           Decimal  @db.Decimal(10, 2)
  receivedAmount   Decimal  @db.Decimal(10, 2)
  changeAmount     Decimal  @db.Decimal(10, 2)
  method           String   // CASH | QR | YAPE
  mode             String   // FULL | PARTIAL
  documentType     String?  // BOLETA | FACTURA
  customerDocument String?
  customerName     String?
  customerEmail    String?
  isTakeaway       Boolean  @default(false)
  pdfPath          String?
  createdAt        DateTime @default(now())

  order      Order?       @relation(fields: [orderId], references: [id])
  table      DiningTable? @relation(fields: [tableId], references: [id])
  receivedBy User         @relation(fields: [receivedById], references: [id])

  @@map("payments")
}

// ─── SUPPLY CATEGORY ─────────────────────────────────────────────────────────

model SupplyCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplies Supply[]

  @@map("supply_categories")
} // -NUEVOv5

// ─── SUPPLY ───────────────────────────────────────────────────────────────────

model Supply {
  id           String      @id @default(cuid())
  name         String      @unique
  unit         SupplyUnit
  currentStock Decimal     @db.Decimal(12, 3) @default(0)
  minStock     Decimal     @db.Decimal(12, 3) @default(0)
  categoryId   String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  category    SupplyCategory @relation(fields: [categoryId], references: [id])
  recipeItems RecipeItem[]

  @@map("supplies")
} // -NUEVOv5

// ─── RECIPE ITEM ──────────────────────────────────────────────────────────────

model RecipeItem {
  id         String   @id @default(cuid())
  menuItemId String
  supplyId   String
  quantity   Decimal  @db.Decimal(12, 3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  supply   Supply   @relation(fields: [supplyId], references: [id])

  @@unique([menuItemId, supplyId])
  @@map("recipe_items")
} // -NUEVOv5

// ─── INCIDENT ─────────────────────────────────────────────────────────────────
// Had-09: Registra pérdidas por liberación forzosa de mesa o ítem sin cobro.

model Incident {
  id            String   @id @default(cuid())
  tableId       Int?                        // mesa afectada (null = para llevar)
  tableNumber   Int?                        // snapshot para historial
  orderId       String?                     // order completo liberado (null si es por ítem)
  orderItemId   String?                     // ítem específico liberado (null si es tabla entera)
  lostAmount    Decimal  @db.Decimal(10, 2) // monto total de la pérdida
  reason        String?                     // motivo opcional (fuga, plato mal servido, etc.)
  itemsSnapshot Json?                       // snapshot de ítems perdidos para el historial
  releasedById  String
  createdAt     DateTime @default(now())

  table        DiningTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  releasedBy   User         @relation(fields: [releasedById], references: [id])

  @@map("incidents")
} // -NUEVOv6
